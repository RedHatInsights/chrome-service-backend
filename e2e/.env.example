# E2E Test Configuration
# Copy this file to .env and fill in your values

# Base URL of the API to test
# For stage: https://console.stage.redhat.com
# For prod: https://console.redhat.com
# For local: http://localhost:8000
E2E_BASE_URL=http://localhost:8000

# Test user credentials for x-rh-identity header
E2E_USER_ID=test-user-123
E2E_ACCOUNT_ID=123456
E2E_ORG_ID=654321
E2E_USERNAME=testuser
