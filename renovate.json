{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "baseBranches": ["main"],
  "extends": [
    "config:base"
  ],
  "tekton": {
    "schedule": ["at any time"]
  },
  "packageRules": [
    {
      "description": "Disable major updates entirely",
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      "description": "Group only minor and patch updates into a single PR",
      "matchPackagePatterns": ["*"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "all dependencies",
      "groupSlug": "all-deps"
    },
    {
      "description": "Track ubi9-minimal minor releases independently so base image security updates are visible",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["registry.access.redhat.com/ubi9-minimal"],
      "allowedVersions": "/^9\\.\\d+$/",
      "pinDigests": true,
      "groupName": "ubi9-minimal base image",
      "groupSlug": "ubi9-minimal"
    }
  ],
  "labels": ["dependencies"]
}