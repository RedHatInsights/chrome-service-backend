name: E2E Tests

# Example workflow for running E2E tests against stage environment
# Copy this to .github/workflows/e2e-tests.yaml and configure secrets

on:
  # Run on pull requests
  pull_request:
    branches:
      - main
  # Run on schedule (e.g., nightly)
  schedule:
    - cron: '0 2 * * *'  # 2 AM daily
  # Allow manual trigger
  workflow_dispatch:

jobs:
  e2e-tests:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout code
        uses: actions/checkout@v7

      - name: Set up Go
        uses: actions/setup-go@v6
        with:
          go-version: '1.26.4'

      - name: Install dependencies
        run: |
          cd e2e
          go mod download

      - name: Run E2E Tests
        env:
          E2E_BASE_URL: https://console.stage.redhat.com
          # These should be configured as GitHub Secrets
          E2E_USER_ID: ${{ secrets.E2E_USER_ID }}
          E2E_ACCOUNT_ID: ${{ secrets.E2E_ACCOUNT_ID }}
          E2E_ORG_ID: ${{ secrets.E2E_ORG_ID }}
          E2E_USERNAME: ${{ secrets.E2E_USERNAME }}
        run: |
          make test-e2e

      - name: Upload test results
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: e2e-test-results
          path: e2e/*.out
